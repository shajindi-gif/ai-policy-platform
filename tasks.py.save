import time
import os
from dotenv import load_dotenv
from openai import OpenAI
from celery_app import celery_app

load_dotenv()

client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

@celery_app.task
def add(x, y):
    return x + y

@celery_app.task
def long_task(seconds):
    time.sleep(seconds)
    return {"status": "done", "slept": seconds}

