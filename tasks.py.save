@celery_app.task
def company_command(command: str):
    try:
        resp = client.responses.create(
            model="gpt-4.1-mini",
            input=f"你是无人公司的执行助理。用户命令是：{command}。请直接输出执行结果。"
        )
        return {
            "status": "success",
            "command": command,
            "output": resp.output_text
        }

    except Exception as e:
        return {
            "status": "fallback",
            "command": command,
            "output": f"已收到任务，但外部AI调用失败：{str(e)}"
        }            "error": str(e)
        }
